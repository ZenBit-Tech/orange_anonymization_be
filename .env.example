
# App
NODE_ENV=development
DEFAULT_NODE_ENV=development
HOST=0.0.0.0
PORT=3000
DEFAULT_APP_PORT=3000
# CORS_ORIGIN must be the URL of the deployed frontend Heroku app in production,
# e.g. https://<frontend-heroku-app>.herokuapp.com
# Use the local Vite dev server URL only for local development.
CORS_ORIGIN=http://localhost:5173
DEFAULT_CORS_ORIGIN=http://localhost:5173

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3307
DEFAULT_DB_PORT=3306
DB_USERNAME=clinical_user
DB_PASSWORD=change_me_in_prod
# Optional aliases supported by config fallback
DB_USER=
DB_PASS=
DB_NAME=clinical_studio
SEED_ADMIN_EMAIL=admin@gmail.com
DB_SYNCHRONIZE=true
DB_LOGGING=false

# JWT
JWT_SECRET=replace_with_a_long_random_string_at_least_65_chars
JWT_EXPIRES_IN=1h

# Magic Link
MAGIC_LINK_EXPIRES_IN=900

# Encryption
ENCRYPTION_KEY=change_me_16chars

# Presidio
PRESIDIO_ANALYZER_URL=http://localhost:5001
PRESIDIO_ANONYMIZER_URL=http://localhost:5002

# Frontend URL — used to build magic-link verification URLs in outgoing emails.
# Point this at the deployed frontend Heroku app in production,
# e.g. https://<frontend-heroku-app>.herokuapp.com
FRONTEND_URL=http://localhost:5173

# Mail
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
DEFAULT_MAIL_PORT=587
MAIL_USER=authzenbit@gmail.com
MAIL_PASS=replace_with_gmail_app_password
MAIL_FROM=authzenbit@gmail.com

